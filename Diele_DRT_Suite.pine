//@version=5
//=============================================================================
//  Diele DRT Suite
//-----------------------------------------------------------------------------
//  Version : 1.0.0
//  Build   : 001
//
//  Author  : Diele48
//
//  Roadmap
//  --------
//  [x] Framework
//  [ ] HTF Engine
//  [ ] Drawing Engine
//  [ ] Dashboard
//  [ ] Sessions
//  [ ] Liquidity
//  [ ] Structure
//  [ ] Smart Money
//  [ ] Entries
//
//=============================================================================

indicator(
     title = "Diele DRT Suite",
     shorttitle = "DRT",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//=============================================================================
// SETTINGS
//=============================================================================

groupGeneral = "General"

htf = input.timeframe("60", "Higher Timeframe", group = groupGeneral)

groupDisplay = "Display"

showLevels     = input.bool(true, "HTF Levels", group = groupDisplay)
showDashboard  = input.bool(true, "Dashboard", group = groupDisplay)
showVerticals  = input.bool(true, "Vertical Lines", group = groupDisplay)
showCounter    = input.bool(true, "Counter", group = groupDisplay)
showCycle      = input.bool(true, "C1-C4", group = groupDisplay)

groupStyle = "Style"

extendLevels = input.bool(true, "Extend Levels", group = groupStyle)

lineWidth = input.int(
     2,
     "Line Width",
     minval = 1,
     maxval = 4,
     group = groupStyle)

levelLength = input.int(
     15,
     "Level Length (bars)",
     minval = 5,
     maxval = 100,
     group = groupStyle)

groupColors = "Colors"

clrHigh = input.color(color.lime, "High", group = groupColors)
clrLow = input.color(color.red, "Low", group = groupColors)
clrOpen = input.color(color.orange, "Open", group = groupColors)
clrMid = input.color(color.aqua, "Mid", group = groupColors)

//=============================================================================
// GLOBAL OBJECTS
//=============================================================================

var line lineHigh = na
var line lineLow = na
var line lineOpen = na
var line lineMid = na
var line lineVertical = na

var label lblDashboard = na
var label lblCounter = na
var label lblCycle = na
var label lblHigh = na
var label lblLow  = na
var label lblOpen = na
var label lblMid  = na

//=============================================================================
// HELPER FUNCTIONS
//=============================================================================

f_extend() =>
    extendLevels ? extend.right : extend.none

//=============================================================================
// MODULES
//=============================================================================

//=============================================================================
// HTF ENGINE
//=============================================================================

// Detect start van nieuwe HTF candle
bool newHTF = ta.change(time(htf)) != 0

// Live HTF waarden
var float htfOpen = na
var float htfHigh = na
var float htfLow  = na
var float htfMid  = na

// Bar waar niveau ontstond
var int htfOpenBar = na
var int htfHighBar = na
var int htfLowBar  = na

// Initialisatie
if barstate.isfirst
    htfOpen := open
    htfHigh := high
    htfLow  := low

    htfOpenBar := bar_index
    htfHighBar := bar_index
    htfLowBar  := bar_index

// Nieuwe HTF candle
if newHTF

    htfOpen := open
    htfHigh := high
    htfLow := low

    htfOpenBar := bar_index
    htfHighBar := bar_index
    htfLowBar := bar_index

// Live update High
if high >= htfHigh
    htfHigh := high
    htfHighBar := bar_index

// Live update Low
if low <= htfLow
    htfLow := low
    htfLowBar := bar_index

// Midpoint
htfMid := (htfHigh + htfLow) * 0.5

// Candles binnen HTF
int barsPerHTF = int(math.round(
     timeframe.in_seconds(htf) /
     timeframe.in_seconds(timeframe.period)))

var int htfBar = 1

if newHTF
    htfBar := 1
else
    htfBar += 1

// C1-C4
var int cPhase = 1

if newHTF
    cPhase := cPhase == 4 ? 1 : cPhase + 1
var float htfClose = na
//=============================================================================
// DRAWING ENGINE
//=============================================================================

if showLevels

    //=========================
    // HIGH
    //=========================

    if na(lineHigh)
        lineHigh := line.new(
             x1 = htfHighBar,
             y1 = htfHigh,
             x2 = bar_index,
             y2 = htfHigh,
             color = clrHigh,
             width = lineWidth,
             extend = f_extend())
    else
        line.set_xy1(lineHigh, htfHighBar, htfHigh)
        line.set_xy2(
     lineHigh,
     htfHighBar + levelLength,
     htfHigh)

    //=========================
    // LOW
    //=========================

    if na(lineLow)
        lineLow := line.new(
             x1 = htfLowBar,
             y1 = htfLow,
             x2 = bar_index,
             y2 = htfLow,
             color = clrLow,
             width = lineWidth,
             extend = f_extend())
    else
        line.set_xy1(lineLow, htfLowBar, htfLow)
       line.set_xy2(
     lineLow,
     htfLowBar + levelLength,
     htfLow)
    //=========================
    // OPEN
    //=========================

    if na(lineOpen)
        lineOpen := line.new(
             x1 = htfOpenBar,
             y1 = htfOpen,
             x2 = bar_index,
             y2 = htfOpen,
             color = clrOpen,
             width = lineWidth,
             extend = f_extend())
    else
        line.set_xy1(lineOpen, htfOpenBar, htfOpen)
       line.set_xy2(
     lineOpen,
     htfOpenBar + levelLength,
     htfOpen)
    //=========================
    // MID
    //=========================

    if na(lineMid)
        lineMid := line.new(
             x1 = htfOpenBar,
             y1 = htfMid,
             x2 = bar_index,
             y2 = htfMid,
             color = clrMid,
             style = line.style_dashed,
             width = 1,
             extend = f_extend())
    else
        line.set_xy1(lineMid, htfOpenBar, htfMid)
      line.set_xy2(
     lineMid,
     htfOpenBar + levelLength,
     htfMid)

else

    if not na(lineHigh)
        line.delete(lineHigh)
        lineHigh := na

    if not na(lineLow)
        line.delete(lineLow)
        lineLow := na

    if not na(lineOpen)
        line.delete(lineOpen)
        lineOpen := na

    if not na(lineMid)
        line.delete(lineMid)
        lineMid := na
//=============================================================================
// LEVEL LABELS
//=============================================================================

if showLevels

    // HIGH
    if na(lblHigh)
        lblHigh := label.new(
             htfHighBar + levelLength + 1,
             htfHigh,
             "crHigh",
             style = label.style_none,
             textcolor = clrHigh,
             size = size.small)
    else
        label.set_xy(lblHigh, htfHighBar, htfHigh)
        label.set_text(lblHigh, "H")

    // LOW
    if na(lblLow)
        lblLow := label.new(
             htfLowBar + levelLength + 1,
             htfLow,
             "crLow",
             style = label.style_none,
             textcolor = clrLow,
             size = size.small)
    else
        label.set_xy(lblLow, htfLowBar, htfLow)
        label.set_text(lblLow, "L")

    // OPEN
    if na(lblOpen)
        lblOpen := label.new(
             htfOpenBar + levelLength + 1,
             htfOpen,
             "O",
             style = label.style_none,
             textcolor = clrOpen,
             size = size.small)
    else
        label.set_xy(lblOpen, htfOpenBar, htfOpen)
        label.set_text(lblOpen, "O")

    // MID
    if na(lblMid)
        lblMid := label.new(
             htfOpenBar + levelLength + 1,
             htfMid,
             "M",
             style = label.style_none,
             textcolor = clrMid,
             size = size.small)
    else
        label.set_xy(lblMid, htfOpenBar, htfMid)
        label.set_text(lblMid, "M")

else

    if not na(lblHigh)
        label.delete(lblHigh)
        lblHigh := na

    if not na(lblLow)
        label.delete(lblLow)
        lblLow := na

    if not na(lblOpen)
        label.delete(lblOpen)
        lblOpen := na

    if not na(lblMid)
        label.delete(lblMid)
        lblMid := na

//=============================================================================
// HTF SEPARATORS
//=============================================================================

if showVerticals and newHTF

    line.new(
         bar_index,
         low - ta.atr(14) * 5,
         bar_index,
         high + ta.atr(14) * 5,
         color = color.new(color.gray, 80),
         style = line.style_dotted,
         width = 1)


//-----------------------------------------------------------------------------
// DASHBOARD
//-----------------------------------------------------------------------------

// (Commit #4)

//-----------------------------------------------------------------------------
// KEEP INDICATOR VALID
//-----------------------------------------------------------------------------

plot(na)
