indicator(
     title = "Diele DRT Suite",
     shorttitle = "DRT",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//=============================================================================
// SETTINGS
//=============================================================================

groupGeneral = "General"

htf = input.timeframe("60", "Higher Timeframe", group = groupGeneral)

showLabels = input.bool(true, "Show Level Labels", group = groupDisplay)

groupDisplay = "Display"

showLevels     = input.bool(true, "HTF Levels", group = groupDisplay)
showDashboard  = input.bool(true, "Dashboard", group = groupDisplay)
showVerticals  = input.bool(true, "Vertical Lines", group = groupDisplay)
showCounter    = input.bool(true, "Counter", group = groupDisplay)
showCycle      = input.bool(true, "C1-C4", group = groupDisplay)

groupStyle = "Style"

showOpen = input.bool(
     false,
     "Show Open",
     group = groupStyle)

showMid = input.bool(
     false,
     "Show Mid",
     group = groupStyle)

lineWidth = input.int(
     2,
     "Line Width",
     minval = 1,
     maxval = 4,
     group = groupStyle)

levelLength = input.int(
     15,
     "Level Length (bars)",
     minval = 5,
     maxval = 100,
     group = groupStyle)

groupColors = "Colors"

clrHigh = input.color(color.rgb(34,139,34), "CR High", group=groupColors)
clrLow  = input.color(color.rgb(178,34,34), "CR Low", group=groupColors)
clrOpen = input.color(color.rgb(218,165,32), "Open", group=groupColors)
clrMid  = input.color(color.rgb(70,130,180), "Mid", group=groupColors)

//=============================================================================
// GLOBAL OBJECTS
//=============================================================================

var line lineHigh = na
var line lineLow = na
var line lineOpen = na
var line lineMid = na
var line lineVertical = na

var label lblDashboard = na
var label lblCounter = na
var label lblCycle = na
var label lblHigh = na
var label lblLow  = na
var label lblOpen = na
var label lblMid  = na

//=============================================================================
// HELPER FUNCTIONS
//=============================================================================


//=============================================================================
// MODULES
//=============================================================================

//=============================================================================
// HTF ENGINE
//=============================================================================

// Detect start van nieuwe HTF candle
bool newHTF = ta.change(time(htf)) != 0

// Live HTF waarden
var float htfOpen = na
var float htfHigh = na
var float htfLow  = na
var float htfMid  = na

// Bar waar niveau ontstond
var int htfOpenBar = na
var int htfHighBar = na
var int htfLowBar  = na

// Initialisatie
if barstate.isfirst
    htfOpen := open
    htfHigh := high
    htfLow  := low

    htfOpenBar := bar_index
    htfHighBar := bar_index
    htfLowBar  := bar_index

// Nieuwe HTF candle
if newHTF

    htfOpen := open
    htfHigh := high
    htfLow := low

    htfOpenBar := bar_index
    htfHighBar := bar_index
    htfLowBar := bar_index

// Live update High
if high >= htfHigh
    htfHigh := high
    htfHighBar := bar_index

// Live update Low
if low <= htfLow
    htfLow := low
    htfLowBar := bar_index

// Midpoint
htfMid := (htfHigh + htfLow) * 0.5

// Candles binnen HTF

var int htfBar = 1

if newHTF
    htfBar := 1
else
    htfBar += 1

// C1-C4
var int cPhase = 1

if newHTF
    cPhase := cPhase == 4 ? 1 : cPhase + 1

//=============================================================================
// DRAW HELPERS
//=============================================================================

f_drawLevel(_line, _x1, _price, _color, _width) =>

    line l = _line

    int x2 = _x1 + levelLength

    if na(l)
        l := line.new(
             x1 = _x1,
             y1 = _price,
             x2 = x2,
             y2 = _price,
             color = _color,
             width = _width)

    else
        line.set_xy1(l, _x1, _price)
        line.set_xy2(l, x2, _price)
        line.set_color(l, _color)
        line.set_width(l, _width)

    l
//=============================================================================
// DRAWING ENGINE
//=============================================================================

if showLevels

    // CR High
    lineHigh := f_drawLevel(
         lineHigh,
         htfHighBar,
         htfHigh,
         clrHigh,
         lineWidth)

    // CR Low
    lineLow := f_drawLevel(
         lineLow,
         htfLowBar,
         htfLow,
         clrLow,
         lineWidth)

    // Open
    if showOpen
        lineOpen := f_drawLevel(
             lineOpen,
             htfOpenBar,
             htfOpen,
             clrOpen,
             lineWidth)
    else
        if not na(lineOpen)
            line.delete(lineOpen)
            lineOpen := na

    // Mid
    if showMid
        lineMid := f_drawLevel(
             lineMid,
             htfOpenBar,
             htfMid,
             clrMid,
             1)
    else
        if not na(lineMid)
            line.delete(lineMid)
            lineMid := na

else

    if not na(lineHigh)
        line.delete(lineHigh)
        lineHigh := na

    if not na(lineLow)
        line.delete(lineLow)
        lineLow := na

    if not na(lineOpen)
        line.delete(lineOpen)
        lineOpen := na

    if not na(lineMid)
        line.delete(lineMid)
        lineMid := na

//=============================================================================
// LEVEL LABELS
//=============================================================================

if showLevels

    lblHigh := f_drawLabel(
         lblHigh,
         htfHighBar + levelLength,
         htfHigh,
         "crHigh",
         clrHigh)

    lblLow := f_drawLabel(
         lblLow,
         htfLowBar + levelLength,
         htfLow,
         "crLow",
         clrLow)

    if showOpen

        lblOpen := f_drawLabel(
             lblOpen,
             htfOpenBar + levelLength,
             htfOpen,
             "Open",
             clrOpen)

    else

        if not na(lblOpen)

            label.delete(lblOpen)

            lblOpen := na

    if showMid

        lblMid := f_drawLabel(
             lblMid,
             htfOpenBar + levelLength,
             htfMid,
             "Mid",
             clrMid)

    else

        if not na(lblMid)

            label.delete(lblMid)

            lblMid := na

else

    if not na(lblHigh)

        label.delete(lblHigh)

        lblHigh := na

    if not na(lblLow)

        label.delete(lblLow)

        lblLow := na

    if not na(lblOpen)

        label.delete(lblOpen)

        lblOpen := na

    if not na(lblMid)

        label.delete(lblMid)

        lblMid := na
//=============================================================================
// LABEL HELPER
//=============================================================================

f_drawLabel(_label, _x, _price, _text, _color) =>

    label lb = _label

    int labelOffset = 2

    if na(lb)

        lb := label.new(
             x = _x + labelOffset,
             y = _price,
             text = _text,
             style = label.style_none,
             textcolor = _color,
             size = size.small)

    else

        label.set_xy(
             lb,
             _x + labelOffset,
             _price)

        label.set_text(
             lb,
             _text)

        label.set_textcolor(
             lb,
             _color)

    lb
//=============================================================================
// HTF SEPARATORS
//=============================================================================

if showVerticals and newHTF

    line.new(
         bar_index,
         low - ta.atr(14) * 5,
         bar_index,
         high + ta.atr(14) * 5,
         color.new(color.gray, 88)
         style=line.style_dashed
         width = 1)


//-----------------------------------------------------------------------------
// DASHBOARD
//-----------------------------------------------------------------------------

// (Commit #4)

//-----------------------------------------------------------------------------
// KEEP INDICATOR VALID
//-----------------------------------------------------------------------------

plot(na)
