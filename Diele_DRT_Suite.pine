//@version=5
//=============================================================================
// DIELE DRT SUITE
// Version : 1.0.1-alpha
// Part    : 1A
//=============================================================================

indicator(
     title = "Diele DRT Suite",
     shorttitle = "DRT",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//=============================================================================
// SETTINGS
//=============================================================================

groupGeneral = "General"

htf = input.timeframe(
     "60",
     "Higher Timeframe",
     group = groupGeneral)

groupDisplay = "Display"

showLevels = input.bool(
     true,
     "Show Levels",
     group = groupDisplay)

showLabels = input.bool(
     true,
     "Show Labels",
     group = groupDisplay)

showVerticals = input.bool(
     true,
     "Show HTF Separators",
     group = groupDisplay)

showDashboard = input.bool(
     true,
     "Dashboard",
     group = groupDisplay)

groupStyle = "Style"

showOpen = input.bool(
     false,
     "Show Open",
     group = groupStyle)

showMid = input.bool(
     false,
     "Show Mid",
     group = groupStyle)

levelLength = input.int(
     15,
     "Level Length",
     minval = 5,
     maxval = 50,
     group = groupStyle)

lineWidth = input.int(
     2,
     "Line Width",
     minval = 1,
     maxval = 4,
     group = groupStyle)

groupColors = "Colors"

clrHigh = input.color(
     color.rgb(34,139,34),
     "CR High",
     group = groupColors)

clrLow = input.color(
     color.rgb(178,34,34),
     "CR Low",
     group = groupColors)

clrOpen = input.color(
     color.rgb(218,165,32),
     "Open",
     group = groupColors)

clrMid = input.color(
     color.rgb(70,130,180),
     "Mid",
     group = groupColors)

//=============================================================================
// GLOBAL OBJECTS
//=============================================================================

var line lineHigh = na
var line lineLow = na
var line lineOpen = na
var line lineMid = na

var label lblHigh = na
var label lblLow = na
var label lblOpen = na
var label lblMid = na

//=============================================================================
// CRT ENGINE
//=============================================================================

enum CRTState
    WaitingC1
    WaitingC2
    Active

enum CRTDirection
    None
    Bullish
    Bearish

var CRTState crtState = CRTState.WaitingC1
var CRTDirection crtDirection = CRTDirection.None

//-------------------------
// Reference Candle (C1)
//-------------------------

var float c1Open  = na
var float c1High  = na
var float c1Low   = na
var float c1Close = na

var int c1Bar = na

//-------------------------
// Active CRT
//-------------------------

var float crHigh = na
var float crLow  = na

var int crHighBar = na
var int crLowBar  = na

//-------------------------
// Sweep info
//-------------------------

var bool bullSweep = false
var bool bearSweep = false

//-------------------------
// New HTF candle
//-------------------------

newHour = ta.change(time(htf))

//=============================================================================
// HOUR BUFFER
//=============================================================================

type HourCandle
    float open
    float high
    float low
    float close

    int startBar
    int highBar
    int lowBar

var HourCandle previousHour = HourCandle.new(na, na, na, na, na)
var HourCandle currentHour  = HourCandle.new(na, na, na, na, na)

newHour = ta.change(time(htf)) != 0

var int currentHighBar = na
var int currentLowBar = na

if newHour

    currentHighBar := bar_index
    currentLowBar := bar_index

    // Bewaar de zojuist gesloten HTF candle
    previousHour := HourCandle.new(
         request.security(syminfo.tickerid, htf, open[1]),
         request.security(syminfo.tickerid, htf, high[1]),
         request.security(syminfo.tickerid, htf, low[1]),
         request.security(syminfo.tickerid, htf, close[1]),
         bar_index)

    // Start nieuwe HTF candle
    currentHour := HourCandle.new(
         request.security(syminfo.tickerid, htf, open),
         request.security(syminfo.tickerid, htf, high),
         request.security(syminfo.tickerid, htf, low),
         request.security(syminfo.tickerid, htf, close),
         bar_index)
//=============================================================================
// CRT STATE MACHINE
//=============================================================================

if newHour

    switch crtState

        //------------------------------------------------------------
        // WAITING FOR C1
        //------------------------------------------------------------

        CRTState.WaitingC1 =>

            c1Open  := request.security(syminfo.tickerid, htf, open[1])
            c1High  := request.security(syminfo.tickerid, htf, high[1])
            c1Low   := request.security(syminfo.tickerid, htf, low[1])
            c1Close := request.security(syminfo.tickerid, htf, close[1])

            c1Bar := bar_index

            bullSweep := false
            bearSweep := false

            crtDirection := CRTDirection.None

            crtState := CRTState.WaitingC2

        //------------------------------------------------------------
        // WAITING FOR C2
        //------------------------------------------------------------

        CRTState.WaitingC2 =>

            float c2High =
                 request.security(syminfo.tickerid, htf, high[1])

            float c2Low =
                 request.security(syminfo.tickerid, htf, low[1])

            float c2Close =
                 request.security(syminfo.tickerid, htf, close[1])

            bullSweep := c2Low < c1Low
            bearSweep := c2High > c1High

            bool closeInside =
                 c2Close <= c1High and
                 c2Close >= c1Low

            if closeInside

                crHigh := c1High
                crLow := c1Low

                crHighBar := c1Bar
                crLowBar := c1Bar

                if bullSweep
                    crtDirection := CRTDirection.Bullish

                if bearSweep
                    crtDirection := CRTDirection.Bearish

                crtState := CRTState.Active

            else

                crtState := CRTState.WaitingC1

        //------------------------------------------------------------
        // ACTIVE CRT
        //------------------------------------------------------------

        CRTState.Active =>

            float currentClose =
                 request.security(syminfo.tickerid, htf, close)

            if currentClose > crHigh or currentClose < crLow

                crtState := CRTState.WaitingC1

                crtDirection := CRTDirection.None

                bullSweep := false
                bearSweep := false

                crHigh := na
                crLow := na

                crHighBar := na
                crLowBar := na

//=============================================================================
// DRAW HELPERS
//=============================================================================

f_drawLevel(_line, _x1, _price, _color, _width) =>

    line l = _line

    int x2 = _x1 + levelLength

    if na(l)

        l := line.new(
             x1 = _x1,
             y1 = _price,
             x2 = x2,
             y2 = _price,
             color = _color,
             width = _width)

    else

        line.set_xy1(
             l,
             _x1,
             _price)

        line.set_xy2(
             l,
             x2,
             _price)

        line.set_color(
             l,
             _color)

        line.set_width(
             l,
             _width)

    l

f_drawLabel(_label, _x, _price, _text, _color) =>

    label lb = _label

    if na(lb)

        lb := label.new(
             x = _x + 2,
             y = _price,
             text = _text,
             style = label.style_none,
             textcolor = _color,
             size = size.small)

    else

        label.set_xy(
             lb,
             _x + 2,
             _price)

        label.set_text(
             lb,
             _text)

        label.set_textcolor(
             lb,
             _color)

    lb

//=============================================================================
// DRAWING ENGINE
//=============================================================================

if showLevels

    //────────────────────────────
    // CR HIGH
    //────────────────────────────

    lineHigh := f_drawLevel(
         lineHigh,
         htfHighBar,
         htfHigh,
         clrHigh,
         lineWidth)

    if showLabels
        lblHigh := f_drawLabel(
             lblHigh,
             htfHighBar + levelLength,
             htfHigh,
             "CR High",
             clrHigh)
    else
        if not na(lblHigh)
            label.delete(lblHigh)
            lblHigh := na

    //────────────────────────────
    // CR LOW
    //────────────────────────────

    lineLow := f_drawLevel(
         lineLow,
         htfLowBar,
         htfLow,
         clrLow,
         lineWidth)

    if showLabels
        lblLow := f_drawLabel(
             lblLow,
             htfLowBar + levelLength,
             htfLow,
             "CR Low",
             clrLow)
    else
        if not na(lblLow)
            label.delete(lblLow)
            lblLow := na

    //────────────────────────────
    // OPEN
    //────────────────────────────

    if showOpen

        lineOpen := f_drawLevel(
             lineOpen,
             htfOpenBar,
             htfOpen,
             clrOpen,
             1)

        if showLabels
            lblOpen := f_drawLabel(
                 lblOpen,
                 htfOpenBar + levelLength,
                 htfOpen,
                 "Open",
                 clrOpen)

    else

        if not na(lineOpen)
            line.delete(lineOpen)
            lineOpen := na

        if not na(lblOpen)
            label.delete(lblOpen)
            lblOpen := na

    //────────────────────────────
    // MID
    //────────────────────────────

    if showMid

        lineMid := f_drawLevel(
             lineMid,
             htfOpenBar,
             htfMid,
             clrMid,
             1)

        if showLabels
            lblMid := f_drawLabel(
                 lblMid,
                 htfOpenBar + levelLength,
                 htfMid,
                 "Mid",
                 clrMid)

    else

        if not na(lineMid)
            line.delete(lineMid)
            lineMid := na

        if not na(lblMid)
            label.delete(lblMid)
            lblMid := na

else

    if not na(lineHigh)
        line.delete(lineHigh)
        lineHigh := na

    if not na(lineLow)
        line.delete(lineLow)
        lineLow := na

    if not na(lineOpen)
        line.delete(lineOpen)
        lineOpen := na

    if not na(lineMid)
        line.delete(lineMid)
        lineMid := na

    if not na(lblHigh)
        label.delete(lblHigh)
        lblHigh := na

    if not na(lblLow)
        label.delete(lblLow)
        lblLow := na

    if not na(lblOpen)
        label.delete(lblOpen)
        lblOpen := na

    if not na(lblMid)
        label.delete(lblMid)
        lblMid := na


//=============================================================================
// KEEP SCRIPT VALID
//=============================================================================

plot(close, display = display.none)

plot(na)
