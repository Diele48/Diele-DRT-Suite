//@version=5
//=============================================================================
// DIELE DRT SUITE
// Version : 1.0.1-alpha
// Part    : 1A
//=============================================================================

indicator(
     title = "Diele DRT Suite",
     shorttitle = "DRT",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//=============================================================================
// SETTINGS
//=============================================================================

groupGeneral = "General"

htf = input.timeframe(
     "60",
     "Higher Timeframe",
     group = groupGeneral)

groupDisplay = "Display"

showLevels = input.bool(
     true,
     "Show Levels",
     group = groupDisplay)

showLabels = input.bool(
     true,
     "Show Labels",
     group = groupDisplay)

showVerticals = input.bool(
     true,
     "Show HTF Separators",
     group = groupDisplay)

showDashboard = input.bool(
     true,
     "Dashboard",
     group = groupDisplay)

groupStyle = "Style"

showOpen = input.bool(
     false,
     "Show Open",
     group = groupStyle)

showMid = input.bool(
     false,
     "Show Mid",
     group = groupStyle)

levelLength = input.int(
     15,
     "Level Length",
     minval = 5,
     maxval = 50,
     group = groupStyle)

lineWidth = input.int(
     2,
     "Line Width",
     minval = 1,
     maxval = 4,
     group = groupStyle)

groupColors = "Colors"

clrHigh = input.color(
     color.rgb(34,139,34),
     "CR High",
     group = groupColors)

clrLow = input.color(
     color.rgb(178,34,34),
     "CR Low",
     group = groupColors)

clrOpen = input.color(
     color.rgb(218,165,32),
     "Open",
     group = groupColors)

clrMid = input.color(
     color.rgb(70,130,180),
     "Mid",
     group = groupColors)

//=============================================================================
// GLOBAL OBJECTS
//=============================================================================

var line lineHigh = na
var line lineLow = na
var line lineOpen = na
var line lineMid = na

var label lblHigh = na
var label lblLow = na
var label lblOpen = na
var label lblMid = na

//=============================================================================
// CRT ENGINE
//=============================================================================

enum CRTState
    WaitingC1
    WaitingC2
    Active

enum CRTDirection
    None
    Bullish
    Bearish
    Both

var CRTState crtState = CRTState.WaitingC1
var CRTDirection crtDirection = CRTDirection.None

//-------------------------
// Reference Candle (C1)
//-------------------------

var float c1Open  = na
var float c1High  = na
var float c1Low   = na
var float c1Close = na

var int c1HighBar = na
var int c1LowBar  = na
//-------------------------
// Active CRT
//-------------------------

var float crHigh = na
var float crLow  = na

var int crHighBar = na
var int crLowBar  = na

//-------------------------
// Sweep info
//-------------------------

var bool bullSweep = false
var bool bearSweep = false

//-------------------------
// New HTF candle
//-------------------------

newHour = ta.change(time(htf))
//=============================================================================
// CRT HELPERS
//=============================================================================

f_storeC1() =>

    c1Open  := request.security(syminfo.tickerid, htf, open[1])
    c1High  := request.security(syminfo.tickerid, htf, high[1])
    c1Low   := request.security(syminfo.tickerid, htf, low[1])
    c1Close := request.security(syminfo.tickerid, htf, close[1])

    // Tijdelijk.
    // In Commit 7 vervangen we dit door de exacte 5m High/Low bar.
    c1HighBar := bar_index
    c1LowBar  := bar_index

    bullSweep := false
    bearSweep := false

    crtDirection := CRTDirection.None


f_activateCRT() =>

    crHigh := c1High
    crLow  := c1Low

    crHighBar := c1HighBar
    crLowBar  := c1LowBar

    if bullSweep and bearSweep
        crtDirection := CRTDirection.None
    else if bullSweep
        crtDirection := CRTDirection.Bullish
    else if bearSweep
        crtDirection := CRTDirection.Bearish
    else
        crtDirection := CRTDirection.None

    crtState := CRTState.Active


f_validateC2() =>

    float c2High =
        request.security(syminfo.tickerid, htf, high[1])

    float c2Low =
        request.security(syminfo.tickerid, htf, low[1])

    float c2Close =
        request.security(syminfo.tickerid, htf, close[1])

    bullSweep := c2Low < c1Low
    bearSweep := c2High > c1High

    bool closeInside =
        c2Close <= c1High and
        c2Close >= c1Low

    if closeInside
        f_activateCRT()
    else
        crtState := CRTState.WaitingC1


f_resetCRT() =>

    crHigh := na
    crLow := na

    crHighBar := na
    crLowBar := na

    bullSweep := false
    bearSweep := false

    crtDirection := CRTDirection.None

    crtState := CRTState.WaitingC1

//=============================================================================
// CRT STATE MACHINE
//=============================================================================

if newHour

    switch crtState

        //------------------------------------------------------------
        // WAITING FOR C1
        //------------------------------------------------------------

        CRTState.WaitingC1 =>

            f_storeC1()

            crtState := CRTState.WaitingC2

        //------------------------------------------------------------
        // WAITING FOR C2
        //------------------------------------------------------------

        CRTState.WaitingC2 =>

            f_validateC2()

        //------------------------------------------------------------
        // ACTIVE CRT
        //------------------------------------------------------------

        CRTState.Active =>

            float currentClose =
                request.security(
                    syminfo.tickerid,
                    htf,
                    close)

            bool outsideCRT =
                currentClose > crHigh or
                currentClose < crLow

            if outsideCRT

                f_resetCRT()
//=============================================================================
// DRAWING ENGINE
//=============================================================================

if showLevels

    //────────────────────────────
    // CR HIGH
    //────────────────────────────

    lineHigh := f_drawLevel(
         lineHigh,
         htfHighBar,
         htfHigh,
         clrHigh,
         lineWidth)

    if showLabels
        lblHigh := f_drawLabel(
             lblHigh,
             htfHighBar + levelLength,
             htfHigh,
             "CR High",
             clrHigh)
    else
        if not na(lblHigh)
            label.delete(lblHigh)
            lblHigh := na

    //────────────────────────────
    // CR LOW
    //────────────────────────────

    lineLow := f_drawLevel(
         lineLow,
         htfLowBar,
         htfLow,
         clrLow,
         lineWidth)

    if showLabels
        lblLow := f_drawLabel(
             lblLow,
             htfLowBar + levelLength,
             htfLow,
             "CR Low",
             clrLow)
    else
        if not na(lblLow)
            label.delete(lblLow)
            lblLow := na

    //────────────────────────────
    // OPEN
    //────────────────────────────

    if showOpen

        lineOpen := f_drawLevel(
             lineOpen,
             htfOpenBar,
             htfOpen,
             clrOpen,
             1)

        if showLabels
            lblOpen := f_drawLabel(
                 lblOpen,
                 htfOpenBar + levelLength,
                 htfOpen,
                 "Open",
                 clrOpen)

    else

        if not na(lineOpen)
            line.delete(lineOpen)
            lineOpen := na

        if not na(lblOpen)
            label.delete(lblOpen)
            lblOpen := na

    //────────────────────────────
    // MID
    //────────────────────────────

    if showMid

        lineMid := f_drawLevel(
             lineMid,
             htfOpenBar,
             htfMid,
             clrMid,
             1)

        if showLabels
            lblMid := f_drawLabel(
                 lblMid,
                 htfOpenBar + levelLength,
                 htfMid,
                 "Mid",
                 clrMid)

    else

        if not na(lineMid)
            line.delete(lineMid)
            lineMid := na

        if not na(lblMid)
            label.delete(lblMid)
            lblMid := na

else

    if not na(lineHigh)
        line.delete(lineHigh)
        lineHigh := na

    if not na(lineLow)
        line.delete(lineLow)
        lineLow := na

    if not na(lineOpen)
        line.delete(lineOpen)
        lineOpen := na

    if not na(lineMid)
        line.delete(lineMid)
        lineMid := na

    if not na(lblHigh)
        label.delete(lblHigh)
        lblHigh := na

    if not na(lblLow)
        label.delete(lblLow)
        lblLow := na

    if not na(lblOpen)
        label.delete(lblOpen)
        lblOpen := na

    if not na(lblMid)
        label.delete(lblMid)
        lblMid := na


//=============================================================================
// KEEP SCRIPT VALID
//=============================================================================

plot(close, display = display.none)

plot(na)
