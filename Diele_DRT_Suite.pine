//@version=5
//=============================================================================
// DIELE DRT SUITE
// Version : 1.0.1-alpha
// Part    : 1A
//=============================================================================

indicator(
     title = "Diele DRT Suite",
     shorttitle = "DRT",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//=============================================================================
// SETTINGS
//=============================================================================

groupGeneral = "General"

htf = input.timeframe(
     "60",
     "Higher Timeframe",
     group = groupGeneral)

groupDisplay = "Display"

showLevels = input.bool(
     true,
     "Show Levels",
     group = groupDisplay)

showLabels = input.bool(
     true,
     "Show Labels",
     group = groupDisplay)

showVerticals = input.bool(
     true,
     "Show HTF Separators",
     group = groupDisplay)

showDashboard = input.bool(
     true,
     "Dashboard",
     group = groupDisplay)

groupStyle = "Style"

showOpen = input.bool(
     false,
     "Show Open",
     group = groupStyle)

showMid = input.bool(
     false,
     "Show Mid",
     group = groupStyle)

levelLength = input.int(
     15,
     "Level Length",
     minval = 5,
     maxval = 50,
     group = groupStyle)

lineWidth = input.int(
     2,
     "Line Width",
     minval = 1,
     maxval = 4,
     group = groupStyle)

groupColors = "Colors"

clrHigh = input.color(
     color.rgb(34,139,34),
     "CR High",
     group = groupColors)

clrLow = input.color(
     color.rgb(178,34,34),
     "CR Low",
     group = groupColors)

clrOpen = input.color(
     color.rgb(218,165,32),
     "Open",
     group = groupColors)

clrMid = input.color(
     color.rgb(70,130,180),
     "Mid",
     group = groupColors)

//=============================================================================
// GLOBAL OBJECTS
//=============================================================================

var line lineHigh = na
var line lineLow = na
var line lineOpen = na
var line lineMid = na

var label lblHigh = na
var label lblLow = na
var label lblOpen = na
var label lblMid = na

//=============================================================================
// HELPER FUNCTIONS
//=============================================================================

f_drawLevel(_line, _x1, _price, _color, _width) =>

    line l = _line

    int x2 = _x1 + levelLength

    if na(l)

        l := line.new(
             x1 = _x1,
             y1 = _price,
             x2 = x2,
             y2 = _price,
             color = _color,
             width = _width)

    else

        line.set_xy1(l, _x1, _price)
        line.set_xy2(l, x2, _price)

        line.set_color(l, _color)
        line.set_width(l, _width)

    l


f_drawLabel(_label, _x, _price, _text, _color) =>

    label lb = _label

    if na(lb)

        lb := label.new(
             x = _x + 3,
             y = _price,
             text = _text,
             style = label.style_none,
             textcolor = _color,
             size = size.small)

    else

        label.set_xy(lb, _x + 3, _price)
        label.set_text(lb, _text)
        label.set_textcolor(lb, _color)

    lb
//=============================================================================
// CRT ENGINE
//=============================================================================

enum CRTState
    WaitingC1
    WaitingC2
    Active

enum CRTDirection
    None
    Bullish
    Bearish
    Both

var CRTState crtState = CRTState.WaitingC1
var CRTDirection crtDirection = CRTDirection.None

//-----------------------------------------------------------------------------
// Reference Candle (C1)
//-----------------------------------------------------------------------------

var float c1Open  = na
var float c1High  = na
var float c1Low   = na
var float c1Close = na

var int c1HighBar = na
var int c1LowBar  = na

//-----------------------------------------------------------------------------
// Candidate Candle (C2)
//-----------------------------------------------------------------------------

var float c2High = na
var float c2Low = na
var float c2Close = na

//-----------------------------------------------------------------------------
// Active CRT
//-----------------------------------------------------------------------------

var float crHigh = na
var float crLow = na

var int crHighBar = na
var int crLowBar = na

//-----------------------------------------------------------------------------
// Validation
//-----------------------------------------------------------------------------

var bool bullSweep = false
var bool bearSweep = false
var bool closeInside = false

//-----------------------------------------------------------------------------
// Runtime
//-----------------------------------------------------------------------------

var float currentClose = na
var bool outsideCRT = false

//-----------------------------------------------------------------------------
// New HTF Candle
//-----------------------------------------------------------------------------

bool newHour = ta.change(time(htf)) != 0
//=============================================================================
// CRT HELPERS
//=============================================================================

f_storeC1() =>

    c1Open := request.security(syminfo.tickerid, htf, open[1])
    c1High := request.security(syminfo.tickerid, htf, high[1])
    c1Low := request.security(syminfo.tickerid, htf, low[1])
    c1Close := request.security(syminfo.tickerid, htf, close[1])

    // Tijdelijk.
    // Commit 9 krijgt de exacte 5m HighBar / LowBar.
    c1HighBar := bar_index
    c1LowBar := bar_index

    bullSweep := false
    bearSweep := false

    crtDirection := CRTDirection.None



f_activateCRT() =>

    crHigh := c1High
    crLow := c1Low

    crHighBar := c1HighBar
    crLowBar := c1LowBar

    if bullSweep and bearSweep
        crtDirection := CRTDirection.Both
    else if bullSweep
        crtDirection := CRTDirection.Bullish
    else if bearSweep
        crtDirection := CRTDirection.Bearish
    else
        crtDirection := CRTDirection.None

    crtState := CRTState.Active



f_validateC2() =>

    c2High = request.security(syminfo.tickerid, htf, high[1])
    c2Low = request.security(syminfo.tickerid, htf, low[1])
    c2Close = request.security(syminfo.tickerid, htf, close[1])

    bullSweep := c2Low < c1Low
    bearSweep := c2High > c1High

    closeInside = c2Close <= c1High and c2Close >= c1Low

    if closeInside
        f_activateCRT()
    else
        crtState := CRTState.WaitingC1



f_resetCRT() =>

    crHigh := na
    crLow := na

    crHighBar := na
    crLowBar := na

    bullSweep := false
    bearSweep := false

    crtDirection := CRTDirection.None

    crtState := CRTState.WaitingC1
//=============================================================================
// CRT STATE MACHINE
//=============================================================================

if newHour

    switch crtState

        //------------------------------------------------------------
        // WAITING FOR C1
        //------------------------------------------------------------

        CRTState.WaitingC1 =>

            f_storeC1()
            crtState := CRTState.WaitingC2

        //------------------------------------------------------------
        // WAITING FOR C2
        //------------------------------------------------------------

        CRTState.WaitingC2 =>

            f_validateC2()

        //------------------------------------------------------------
        // ACTIVE CRT
        //------------------------------------------------------------

        CRTState.Active =>

            currentClose = request.security(syminfo.tickerid, htf, close)

            outsideCRT = currentClose > crHigh or currentClose < crLow

            if outsideCRT
                f_resetCRT()
//=============================================================================
// DRAWING ENGINE
//=============================================================================

if showLevels and crtState == CRTState.Active

    //────────────────────────────
    // CR HIGH
    //────────────────────────────

    lineHigh := f_drawLevel(
         lineHigh,
         crHighBar,
         crHigh,
         clrHigh,
         lineWidth)

    if showLabels

        lblHigh := f_drawLabel(
             lblHigh,
             crHighBar + levelLength,
             crHigh,
             "CR High",
             clrHigh)

    else

        if not na(lblHigh)
            label.delete(lblHigh)
            lblHigh := na

    //────────────────────────────
    // CR LOW
    //────────────────────────────

    lineLow := f_drawLevel(
         lineLow,
         crLowBar,
         crLow,
         clrLow,
         lineWidth)

    if showLabels

        lblLow := f_drawLabel(
             lblLow,
             crLowBar + levelLength,
             crLow,
             "CR Low",
             clrLow)

    else

        if not na(lblLow)
            label.delete(lblLow)
            lblLow := na

    //────────────────────────────
    // OPEN
    //────────────────────────────

    if showOpen

        lineOpen := f_drawLevel(
             lineOpen,
             c1HighBar,
             c1Open,
             clrOpen,
             1)

        if showLabels

            lblOpen := f_drawLabel(
                 lblOpen,
                 c1HighBar + levelLength,
                 c1Open,
                 "Open",
                 clrOpen)

    else

        if not na(lineOpen)
            line.delete(lineOpen)
            lineOpen := na

        if not na(lblOpen)
            label.delete(lblOpen)
            lblOpen := na

    //────────────────────────────
    // MID
    //────────────────────────────

    if showMid

        float crMid = (crHigh + crLow) * 0.5

        lineMid := f_drawLevel(
             lineMid,
             c1HighBar,
             crMid,
             clrMid,
             1)

        if showLabels

            lblMid := f_drawLabel(
                 lblMid,
                 c1HighBar + levelLength,
                 crMid,
                 "Mid",
                 clrMid)

    else

        if not na(lineMid)
            line.delete(lineMid)
            lineMid := na

        if not na(lblMid)
            label.delete(lblMid)
            lblMid := na

else

    if not na(lineHigh)
        line.delete(lineHigh)
        lineHigh := na

    if not na(lineLow)
        line.delete(lineLow)
        lineLow := na

    if not na(lineOpen)
        line.delete(lineOpen)
        lineOpen := na

    if not na(lineMid)
        line.delete(lineMid)
        lineMid := na

    if not na(lblHigh)
        label.delete(lblHigh)
        lblHigh := na

    if not na(lblLow)
        label.delete(lblLow)
        lblLow := na

    if not na(lblOpen)
        label.delete(lblOpen)
        lblOpen := na

    if not na(lblMid)
        label.delete(lblMid)
        lblMid := na

//=============================================================================
// DASHBOARD
//=============================================================================

if showDashboard

    if na(dashboard)

        dashboard := table.new(
             position.top_right,
             2,
             6,
             bgcolor = color.new(color.black, 80),
             border_width = 1)

    string stateTxt = ""

    switch crtState
        CRTState.WaitingC1 => stateTxt := "Waiting C1"
        CRTState.WaitingC2 => stateTxt := "Waiting C2"
        CRTState.Active    => stateTxt := "ACTIVE"

    string dirTxt = ""

    switch crtDirection
        CRTDirection.None     => dirTxt := "-"
        CRTDirection.Bullish  => dirTxt := "Bullish"
        CRTDirection.Bearish  => dirTxt := "Bearish"
        CRTDirection.Both     => dirTxt := "Both"

    table.cell(dashboard, 0, 0, "Diele DRT Suite", text_color=color.white)
    table.cell(dashboard, 1, 0, "v1.1", text_color=color.orange)

    table.cell(dashboard, 0, 1, "CRT")
    table.cell(dashboard, 1, 1, stateTxt)

    table.cell(dashboard, 0, 2, "Direction")
    table.cell(dashboard, 1, 2, dirTxt)

    table.cell(dashboard, 0, 3, "CR High")
    table.cell(dashboard, 1, 3, na(crHigh) ? "-" : str.tostring(crHigh, format.mintick))

    table.cell(dashboard, 0, 4, "CR Low")
    table.cell(dashboard, 1, 4, na(crLow) ? "-" : str.tostring(crLow, format.mintick))

    table.cell(dashboard, 0, 5, "HTF")
    table.cell(dashboard, 1, 5, htf)

else

    if not na(dashboard)

        table.clear(dashboard)
//=============================================================================
// KEEP SCRIPT VALID
//=============================================================================

plot(close, display = display.none)

plot(na)
